@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Hospital Users";
}

<h2>Hospital Users</h2>

@if (TempData["Message"] != null)
{
    <p style="color:green;">@TempData["Message"]</p>
}

<p>
    <a asp-action="Create">Create Doctor or Patient</a>
</p>

<table>
    <thead>
        <tr>
            <th>Full Name</th>
            <th>Email</th>
            <th>Role</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>@user.Role</td>
            </tr>
        }
    </tbody>
</table>