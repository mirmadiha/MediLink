@using MediLink.Domain

@{
    ViewData["Title"] = "Home";
}

<h2>MediLink Dashboard</h2>

<p>Welcome, @User.Identity?.Name</p>

@if (User.IsInRole(Roles.MasterAdmin))
{
    <p><a asp-controller="Hospitals" asp-action="Index">Manage Hospitals</a></p>
    <p><a asp-controller="Hospitals" asp-action="Create">Create Hospital Admin</a></p>
}

@if (User.IsInRole(Roles.Admin))
{
    <p><a asp-controller="Users" asp-action="Index">View Hospital Users</a></p>
    <p><a asp-controller="Users" asp-action="Create">Create Doctor/Patient</a></p>
}

<form asp-controller="Account" asp-action="Logout" method="post">
    <button type="submit">Logout</button>
</form>