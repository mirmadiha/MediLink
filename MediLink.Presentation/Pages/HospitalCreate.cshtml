@model MediLink.Presentation.Models.CreateHospitalAdminViewModel

@{
    ViewData["Title"] = "Create Hospital";
}

<h2>Create Hospital and Admin</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div>
        <label asp-for="HospitalName"></label>
        <input asp-for="HospitalName" />
        <span asp-validation-for="HospitalName" class="text-danger"></span>
    </div>

    <div style="margin-top:10px;">
        <label asp-for="AdminFullName"></label>
        <input asp-for="AdminFullName" />
        <span asp-validation-for="AdminFullName" class="text-danger"></span>
    </div>

    <div style="margin-top:10px;">
        <label asp-for="AdminEmail"></label>
        <input asp-for="AdminEmail" />
        <span asp-validation-for="AdminEmail" class="text-danger"></span>
    </div>

    <div style="margin-top:10px;">
        <label asp-for="AdminPassword"></label>
        <input asp-for="AdminPassword" />
        <span asp-validation-for="AdminPassword" class="text-danger"></span>
    </div>

    <div style="margin-top:15px;">
        <button type="submit">Save</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}