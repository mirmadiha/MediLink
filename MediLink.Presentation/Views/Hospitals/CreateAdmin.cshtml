@model CreateAdminViewModel

@{
    ViewData["Title"] = "Create Admin";
}

<h2>Create Admin</h2>
<p>Create an admin account and assign it to an existing hospital.</p>

@if (!Model.Hospitals.Any())
{
    <p class="text-danger">No hospitals found. Please create a hospital first.</p>
}

<form asp-action="CreateAdmin" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div>
        <label asp-for="HospitalId"></label>
        <select asp-for="HospitalId" disabled="@(!Model.Hospitals.Any())">
            <option value="">Select hospital</option>
            @foreach (var hospital in Model.Hospitals)
            {
                <option value="@hospital.Id">@hospital.Name</option>
            }
        </select>
        <span asp-validation-for="HospitalId" class="text-danger"></span>
    </div>

    <div style="margin-top:10px;">
        <label asp-for="AdminFullName"></label>
        <input asp-for="AdminFullName" />
        <span asp-validation-for="AdminFullName" class="text-danger"></span>
    </div>

    <div style="margin-top:10px;">
        <label asp-for="Contact"></label>
        <input asp-for="Contact" />
        <span asp-validation-for="Contact" class="text-danger"></span>
    </div>

    <div style="margin-top:10px;">
        <label asp-for="AdminEmail"></label>
        <input asp-for="AdminEmail" />
        <span asp-validation-for="AdminEmail" class="text-danger"></span>
    </div>

    <div style="margin-top:10px;">
        <label asp-for="AdminPassword"></label>
        <input asp-for="AdminPassword" />
        <span asp-validation-for="AdminPassword" class="text-danger"></span>
    </div>

    <div style="margin-top:15px;">
        <button type="submit" disabled="@(!Model.Hospitals.Any())">Save</button>
    </div>
</form>
