@{
    ViewData["Title"] = "Home";
}

<h2>Welcome to MediLink</h2>

@if (!User.Identity?.IsAuthenticated ?? true)
{
    <p>Your healthcare access starts here. Please login or signup to continue.</p>

    <p><a asp-controller="Account" asp-action="Login">Login</a></p>
    <p><a asp-controller="Account" asp-action="Signup">Signup (Patients Only)</a></p>
}
else
{
    <p>Welcome, @User.Identity?.Name</p>

    @if (User.IsInRole(Roles.MasterAdmin))
    {
        <p><a asp-controller="Hospitals" asp-action="Index">Manage Hospitals</a></p>
        <p><a asp-controller="Hospitals" asp-action="Create">Create Hospital</a></p>
        <p><a asp-controller="Hospitals" asp-action="CreateAdmin">Create Admin</a></p>
    }

    @if (User.IsInRole(Roles.Admin))
    {
        <p><a asp-controller="Users" asp-action="Index">View Hospital Users</a></p>
        <p><a asp-controller="Users" asp-action="Create">Create Doctor</a></p>
    }

    @if (User.IsInRole(Roles.Doctor))
    {
        <p><a asp-controller="Doctor" asp-action="Index">Search Patient by ABHA ID</a></p>
        <p><a asp-controller="Doctor" asp-action="AISummary">AI Summary</a></p>
    }

    @if (User.IsInRole(Roles.Patient))
    {
        <p><a asp-controller="Account" asp-action="MyPrescriptions">View My Prescriptions</a></p>
    }

    <form asp-controller="Account" asp-action="Logout" method="post">
        <button type="submit">Logout</button>
    </form>
}
