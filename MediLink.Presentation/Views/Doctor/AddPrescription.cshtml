@model PrescriptionFormViewModel

@{
    ViewData["Title"] = "Add Prescription";
}

<h2>Add Prescription</h2>

@if (TempData["Message"] != null)
{
    <p style="color: green;">@TempData["Message"]</p>
}

<form asp-action="AddPrescription" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <input asp-for="AbhaId" type="hidden" />

    <div>
        <label asp-for="Date"></label>
        <input asp-for="Date" type="date" />
        <span asp-validation-for="Date" class="text-danger"></span>
    </div>

    <div style="margin-top:10px;">
        <label asp-for="PatientName"></label>
        <input asp-for="PatientName" />
        <span asp-validation-for="PatientName" class="text-danger"></span>
    </div>

    <div style="margin-top:10px;">
        <label asp-for="Age"></label>
        <input asp-for="Age" type="number" min="0" />
        <span asp-validation-for="Age" class="text-danger"></span>
    </div>

    <div style="margin-top:10px;">
        <label asp-for="PrescriptionText"></label>
        <textarea asp-for="PrescriptionText" rows="6"></textarea>
        <span asp-validation-for="PrescriptionText" class="text-danger"></span>
    </div>

    <div style="margin-top:10px;">
        <label asp-for="DoctorSignature"></label>
        <input asp-for="DoctorSignature" />
        <span asp-validation-for="DoctorSignature" class="text-danger"></span>
    </div>

    <div style="margin-top:15px;">
        <button type="submit">Save Prescription</button>
    </div>
</form>
