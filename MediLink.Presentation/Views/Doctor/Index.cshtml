@model DoctorDashboardViewModel

@{
    ViewData["Title"] = "Doctor Dashboard";
}

<h2>Search Patient by ABHA ID</h2>

<form asp-action="Index" method="get" style="margin-bottom: 1rem;">
    <label for="abhaId">ABHA ID</label>
    <div style="display:flex; gap:0.75rem; align-items:end; margin-top:0.35rem; flex-wrap:wrap;">
        <input id="abhaId" name="abhaId" value="@Model.SearchAbhaId" placeholder="Enter ABHA ID" maxlength="14" />
        <button type="submit">Search</button>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.SearchAbhaId))
{
    if (Model.Patient != null)
    {
        <div style="margin-bottom:1rem; padding:1rem; border:1px solid var(--border); border-radius:8px; background:#f8fafc;">
            <h3 style="margin-top:0;">Patient Details</h3>
            <p><strong>Name:</strong> @Model.Patient.FullName</p>
            <p><strong>DOB:</strong> @Model.Patient.DateOfBirth</p>
            <p><strong>Age:</strong> @Model.Patient.Age</p>
            <p><strong>Blood Group:</strong> @Model.Patient.BloodGroup</p>
            <p><strong>Previous Diseases:</strong> @Model.Patient.PreviousDiseases</p>
            <p style="margin-top:0.75rem;">
                <a asp-controller="Doctor" asp-action="AddPrescription" asp-route-abhaId="@Model.SearchAbhaId">Add Prescription</a>
                <a asp-controller="Doctor" asp-action="Prescriptions" asp-route-abhaId="@Model.SearchAbhaId" style="margin-left: 12px;">View Prescriptions</a>
            </p>
        </div>
    }
    else
    {
        <p class="text-danger">No patient found for this ABHA ID.</p>
    }
}
