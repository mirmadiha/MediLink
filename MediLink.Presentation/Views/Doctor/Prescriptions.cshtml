@model DoctorPrescriptionPageViewModel

@{
    ViewData["Title"] = "Patient Prescriptions";
}

<h2>Patient Prescriptions</h2>

<div asp-validation-summary="All" class="text-danger"></div>

@if (!string.IsNullOrWhiteSpace(Model.AbhaId))
{
    <p><strong>Patient:</strong> @Model.PatientName</p>

    if (Model.Prescriptions.Any())
    {
        @foreach (var prescription in Model.Prescriptions)
        {
            <div style="margin-bottom:1rem; padding:1rem; border:1px solid var(--border); border-radius:8px; background:#f8fafc;">
                <p><strong>Created:</strong> @prescription.CreatedOn</p>
                <pre style="white-space:pre-wrap; margin:0;">@prescription.Content</pre>
            </div>
        }
    }
    else
    {
        <p>No prescriptions found for this patient.</p>
    }
}
else
{
    <p>Search a patient by ABHA ID first, then use View Prescriptions.</p>
}
