@model PatientPrescriptionPageViewModel

@{
    ViewData["Title"] = "My Prescriptions";
}

<h2>My Prescriptions</h2>
<p>Showing prescriptions linked to your account.</p>

@if (Model.Prescriptions.Any())
{
    @foreach (var prescription in Model.Prescriptions)
    {
        <div style="margin-bottom:1rem; padding:1rem; border:1px solid var(--border); border-radius:8px; background:#f8fafc;">
            <p><strong>Created:</strong> @prescription.CreatedOn</p>
            <pre style="white-space:pre-wrap; margin:0;">@prescription.Content</pre>
        </div>
    }
}
else
{
    <p>No prescriptions found for your account.</p>
}
