@model PatientSignupViewModel

@{
    ViewData["Title"] = "Signup";
}

<h2>Patient Signup</h2>
<p>This signup page is for patients only.</p>

<form asp-action="Signup" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div>
        <label asp-for="FullName"></label>
        <input asp-for="FullName" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>

    <div style="margin-top:10px;">
        <label asp-for="Email"></label>
        <input asp-for="Email" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div style="margin-top:10px;">
        <label asp-for="Password"></label>
        <input asp-for="Password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <div style="margin-top:10px;">
        <label asp-for="ConfirmPassword"></label>
        <input asp-for="ConfirmPassword" />
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
    </div>

    <div style="margin-top:10px;">
        <label asp-for="AbhaId"></label>
        <div style="display:flex; gap:0.75rem; align-items:center; flex-wrap:wrap;">
            <input asp-for="AbhaId" maxlength="14" inputmode="numeric" pattern="[0-9]{14}" />
            <button type="button" id="generateOtpButton" disabled>Generate OTP</button>
        </div>
        <span asp-validation-for="AbhaId" class="text-danger"></span>
    </div>

    <div id="otpField" style="margin-top:10px; display:none;">
        <label asp-for="OtpCode"></label>
        <input asp-for="OtpCode" maxlength="4" inputmode="numeric" pattern="[0-9]{4}" />
        <span asp-validation-for="OtpCode" class="text-danger"></span>
    </div>

    <div style="margin-top:15px;">
        <button type="submit">Create Patient Account</button>
    </div>
</form>

@section Scripts {
    <script>
        (function () {
            const generateOtpButton = document.getElementById('generateOtpButton');
            const otpField = document.getElementById('otpField');
            const abhaInput = document.getElementById('AbhaId');

            if (!generateOtpButton || !otpField || !abhaInput) {
                return;
            }

            function syncGenerateButtonState() {
                const digitsOnly = abhaInput.value.replace(/\D/g, '').slice(0, 14);
                if (abhaInput.value !== digitsOnly) {
                    abhaInput.value = digitsOnly;
                }

                generateOtpButton.disabled = digitsOnly.length !== 14;
            }

            abhaInput.addEventListener('input', syncGenerateButtonState);
            syncGenerateButtonState();

            generateOtpButton.addEventListener('click', function () {
                otpField.style.display = 'block';
                const otpInput = otpField.querySelector('input');
                if (otpInput) {
                    otpInput.focus();
                }
            });
        })();
    </script>
}
